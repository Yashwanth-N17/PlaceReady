generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  STUDENT
  FACULTY
  PLACEMENT
}
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}