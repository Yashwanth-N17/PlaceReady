generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  password            String
  role                Role            @default(STUDENT)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  refreshToken        String?
  fullName            String?
  name                String?
  usn                 String?         @unique
  department          String?
  subjects            String[]        @default([])
  mentorId            String?
  mentor              User?           @relation("Mentees", fields: [mentorId], references: [id])
  mentees             User[]          @relation("Mentees")
  StudentProfile      StudentProfile?
  questions           Question[]
  createdAssessments  Assessment[]    @relation("CreatedAssessments")
  assignedAssessments Assessment[]    @relation("AssignedAssessments")
  assessmentAttempts  AssessmentAttempt[]
  appliedDrives       PlacementDrive[] @relation("DriveApplications")
  notifications       Notification[]
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO") 
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Question {
  id           String       @id @default(uuid())
  text         String
  answer       String
  options      Json?    
  type         String       @default("MCQ") 
  subject      String?
  topic        String?
  difficulty   String?  
  isVisible    Boolean      @default(false)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  uploadedById String
  tags         Tag[]        @relation("QuestionTags")
  assessments  Assessment[] @relation("AssessmentQuestions")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Assessment {
  id           String     @id @default(uuid())
  title        String
  description  String?
  type         String     
  subject      String?
  topic        String?
  scheduledAt  DateTime
  duration     Int        
  questions    Question[] @relation("AssessmentQuestions")
  createdById  String
  createdBy    User       @relation("CreatedAssessments", fields: [createdById], references: [id])
  students     User[]     @relation("AssignedAssessments")
  attempts     AssessmentAttempt[]
  resultsReleased Boolean  @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AssessmentAttempt {
  id              String     @id @default(uuid())
  score           Float
  correctCount    Int
  totalCount      Int
  timeTaken       Int        // in seconds
  focusLossCount  Int        @default(0)
  answers         Json       // questionId -> response
  
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  
  assessmentId    String
  assessment      Assessment @relation(fields: [assessmentId], references: [id])
  
  createdAt       DateTime   @default(now())
}

model Company {
  id             String           @id @default(uuid())
  name           String           @unique
  role           String?
  ctc            String?
  minCgpa        Float?           @default(7.0)
  minReadiness   Float?           @default(70.0)
  minApt         Float?           @default(70.0)
  minCode        Float?           @default(70.0)
  branches       String[]
  requiredSkills String[]
  
  industry       String?
  description    String?
  logoUrl        String?
  website        String?
  drives         PlacementDrive[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PlacementDrive {
  id           String     @id @default(uuid())
  title        String
  description  String?
  date         DateTime
  location     String?
  role         String?    // e.g. Software Engineer
  type         String     @default("FULL_TIME") // FULL_TIME, INTERNSHIP
  status       String     @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED
  salary       String?
  
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  
  students     User[]     @relation("DriveApplications")
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  questions Question[] @relation("QuestionTags")
}

model StudentProfile {
  id              String  @id
  userId          String  @unique
  aptitudeScore   Float?
  codingScore     Float?
  coreScore       Float?
  softSkillsScore Float?
  cgpa            Float?
  attendance      Float?
  branch          String?
  semester        Int?
  readinessScore  Float?
  aiFeedback      String?
  placementStatus String  @default("UNPLACED")
  User            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  FACULTY
  PLACEMENT
}
